rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    match /devices/{deviceId} {
      // Owner can read their device
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      // Owner can update name, tripWatts and safeWatts only
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.diff(resource.data)
           .affectedKeys().hasOnly(['name', 'tripWatts', 'safeWatts']);
      // All other writes go through Cloud Functions (admin SDK)
      allow write: if false;
    }
    match /readings/{readingId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }
    // pairing_sessions collection is no longer used — token flow removed
  }
}
